<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap"
      fetchpriority="low"
    >

    <style>
      /* Trajectus Magna — Brutalist Minimalism */
      :root {
        --font-heading--family: 'Cormorant Garamond', Georgia, serif;
        --font-body--family: 'DM Sans', system-ui, sans-serif;
        --font-subheading--family: 'Cormorant Garamond', Georgia, serif;
        --font-accent--family: 'DM Sans', system-ui, sans-serif;
        --font-primary--family: 'Cormorant Garamond', Georgia, serif;
        --font-secondary--family: 'DM Sans', system-ui, sans-serif;
      }

      /* Force dark palette on all light color schemes */
      .color-scheme-1,
      .color-scheme-2,
      .color-scheme-3 {
        --color-background: rgb(0 0 0);
        --color-background-rgb: 0 0 0;
        --color-foreground: rgb(255 255 255);
        --color-foreground-rgb: 255 255 255;
        --color-foreground-heading: rgb(255 255 255);
        --color-foreground-heading-rgb: 255 255 255;
        --color-border: rgb(34 34 34);
        --color-border-rgb: 34 34 34;
        --color-primary: rgb(136 136 136);
        --color-primary-rgb: 136 136 136;
        --color-primary-hover: rgb(255 255 255);
        --color-primary-button-background: rgb(255 255 255);
        --color-primary-button-text: rgb(0 0 0);
        --color-primary-button-border: rgb(255 255 255);
        --color-primary-button-hover-background: rgb(200 200 200);
        --color-primary-button-hover-text: rgb(0 0 0);
        --color-primary-button-hover-border: rgb(200 200 200);
        --color-secondary-button-background: rgb(0 0 0 / 0);
        --color-secondary-button-text: rgb(255 255 255);
        --color-secondary-button-border: rgb(136 136 136);
        --color-secondary-button-hover-background: rgb(0 0 0 / 0);
        --color-secondary-button-hover-text: rgb(136 136 136);
        --color-secondary-button-hover-border: rgb(100 100 100);
        --color-input-background: rgb(0 0 0);
        --color-input-text: rgb(255 255 255);
        --color-input-text-rgb: 255 255 255;
        --color-input-border: rgb(51 51 51);
        --color-input-hover-background: rgb(17 17 17);
        --color-variant-background: rgb(0 0 0);
        --color-variant-text: rgb(255 255 255);
        --color-variant-border: rgb(51 51 51);
        --color-variant-hover-background: rgb(17 17 17);
        --color-variant-hover-text: rgb(255 255 255);
        --color-variant-hover-border: rgb(136 136 136);
        --color-selected-variant-background: rgb(255 255 255);
        --color-selected-variant-text: rgb(0 0 0);
        --color-selected-variant-border: rgb(255 255 255);
        --color-selected-variant-hover-background: rgb(200 200 200);
        --color-selected-variant-hover-text: rgb(0 0 0);
        --color-selected-variant-hover-border: rgb(200 200 200);
        --opacity-5-15: 0.15;
        --opacity-10-25: 0.25;
        --opacity-35-55: 0.55;
        --opacity-40-60: 0.60;
        --opacity-30-60: 0.60;
      }

      body {
        background: #000000;
      }
    </style>

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    <link rel="stylesheet" href="{{ 'tm-tokens.css' | asset_url }}">
    <link rel="stylesheet" href="{{ 'tm-global.css' | asset_url }}">

    <script>
      /* Modo drop: pre-drop antes de la fecha, post-drop después.
         Override de desarrollo: ?tm_mode=pre | ?tm_mode=post (persiste en la sesión). */
      (function () {
        var DROP_DATE = '2026-06-05T18:00:00+02:00';
        var mode = null;
        try {
          var q = new URLSearchParams(location.search).get('tm_mode');
          if (q === 'pre' || q === 'post') sessionStorage.setItem('tm_mode', q);
          mode = sessionStorage.getItem('tm_mode');
        } catch (e) { /* sessionStorage no disponible */ }
        if (mode !== 'pre' && mode !== 'post') {
          mode = Date.now() >= new Date(DROP_DATE).getTime() ? 'post' : 'pre';
        }
        document.documentElement.classList.add(mode + '-drop');
      })();
    </script>

    {{ content_for_header }}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    {%- render 'tm-header' -%}
    {% unless template == 'index' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>
    {% endunless %}

    <script>
      // Inline header height calculation to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight() and updateTransparentHeaderOffset()utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% unless template == 'index' %}
    <div id="footer-group">
      {% sections 'footer-group' %}
    </div>
    {% endunless %}
    {%- render 'tm-footer' -%}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
