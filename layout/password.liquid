<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex">
  <title>TRAJECTUS MAGNA</title>
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}
  {{ content_for_header }}
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height:      100%;
      background:  #0a0a0a;
      color:       #f0ede8;
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      overflow-x:  hidden;
    }

    .pw-page {
      min-height:      100vh;
      display:         flex;
      flex-direction:  column;
      align-items:     center;
      justify-content: center;
      padding:         40px 24px;
      text-align:      center;
    }

    /* 1. Date stamp */
    .pw-date {
      font-size:      10px;
      letter-spacing: 0.3em;
      color:          rgba(240,237,232,0.2);
      text-transform: uppercase;
      margin-bottom:  48px;
    }

    /* 2. Logo */
    .pw-logo {
      display: block;
      width:   52px;
      height:  auto;
      filter:  invert(1) brightness(10);
    }

    /* 3. Brand name */
    .pw-brand {
      font-size:      10px;
      letter-spacing: 0.5em;
      color:          rgba(240,237,232,0.5);
      text-transform: uppercase;
      margin-top:     16px;
    }

    /* 4. Thin line */
    .pw-line {
      width:      40px;
      height:     1px;
      background: rgba(240,237,232,0.1);
      margin:     32px auto;
    }

    /* 5. Countdown */
    .pw-countdown {
      display: flex;
      gap:     32px;
      align-items: flex-start;
    }

    .pw-countdown__unit {
      display:        flex;
      flex-direction: column;
      align-items:    center;
      gap:            8px;
    }

    .pw-countdown__num {
      font-size:      32px;
      font-weight:    200;
      color:          #f0ede8;
      letter-spacing: -0.01em;
      line-height:    1;
    }

    .pw-countdown__label {
      font-size:      8px;
      letter-spacing: 0.2em;
      color:          rgba(240,237,232,0.25);
      text-transform: uppercase;
    }

    /* 6. Spacer */
    .pw-spacer { height: 48px; }

    /* 7. Access button */
    .pw-access-btn {
      font-size:      9px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color:          rgba(240,237,232,0.3);
      background:     transparent;
      border:         none;
      cursor:         pointer;
      transition:     color 0.4s ease;
      font-family:    inherit;
    }

    .pw-access-btn:hover { color: rgba(240,237,232,0.6); }

    /* 8. Password form */
    #pw-form-wrap {
      opacity:        0;
      transform:      translateY(8px);
      transition:     opacity 0.4s ease, transform 0.4s ease;
      pointer-events: none;
      margin-top:     24px;
    }

    #pw-form-wrap.pw-form--visible {
      opacity:        1;
      transform:      translateY(0);
      pointer-events: all;
    }

    .pw-input {
      display:        block;
      width:          200px;
      background:     transparent;
      border:         none;
      border-bottom:  1px solid rgba(240,237,232,0.2);
      color:          #f0ede8;
      font-family:    inherit;
      font-size:      13px;
      letter-spacing: 0.1em;
      text-align:     center;
      outline:        none;
      padding:        8px 0;
      caret-color:    #f0ede8;
      transition:     border-bottom-color 0.4s ease;
      -webkit-appearance: none;
    }

    .pw-input:focus { border-bottom-color: rgba(240,237,232,0.5); }

    .pw-input::placeholder {
      color:          rgba(240,237,232,0.25);
      letter-spacing: 0.1em;
    }

    .pw-submit {
      display:        block;
      margin:         16px auto 0;
      background:     transparent;
      border:         1px solid rgba(240,237,232,0.15);
      color:          rgba(240,237,232,0.4);
      font-family:    inherit;
      font-size:      9px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      padding:        10px 28px;
      cursor:         pointer;
      transition:     border-color 0.4s ease, color 0.4s ease;
    }

    .pw-submit:hover {
      border-color: rgba(240,237,232,0.4);
      color:        rgba(240,237,232,0.7);
    }

    .pw-form-errors {
      margin-top:     12px;
      font-size:      9px;
      letter-spacing: 0.15em;
      color:          rgba(240,237,232,0.35);
      text-transform: uppercase;
    }

    /* 9. Bottom signature */
    .pw-signature {
      position:     fixed;
      bottom:       24px;
      width:        100%;
      text-align:   center;
      font-size:    10px;
      color:        rgba(240,237,232,0.15);
      letter-spacing: 0.1em;
    }

    @media (prefers-reduced-motion: reduce) {
      .pw-access-btn,
      .pw-submit,
      .pw-input,
      #pw-form-wrap { transition: none; }
    }
  </style>
</head>
<body>

  <main class="pw-page">

    <p class="pw-date">05 &middot; VI &middot; MMXXVI</p>

    {%- if settings.logo != blank -%}
      <img
        src="{{ settings.logo | image_url: width: 104 }}"
        alt="Trajectus Magna"
        class="pw-logo"
        width="52"
        height="{{ 52 | divided_by: settings.logo.aspect_ratio | round }}"
        loading="eager"
      >
    {%- endif -%}

    <p class="pw-brand">TRAJECTUS MAGNA</p>

    <div class="pw-line" aria-hidden="true"></div>

    <div
      class="pw-countdown"
      role="timer"
      aria-label="Cuenta regresiva para el lanzamiento"
      data-tm-countdown
      data-tm-deadline="2026-06-05T18:00:00+02:00"
    >
      <div class="pw-countdown__unit">
        <span class="pw-countdown__num" data-tm-unit="days">00</span>
        <span class="pw-countdown__label">D&Iacute;AS</span>
      </div>
      <div class="pw-countdown__unit">
        <span class="pw-countdown__num" data-tm-unit="hours">00</span>
        <span class="pw-countdown__label">HORAS</span>
      </div>
      <div class="pw-countdown__unit">
        <span class="pw-countdown__num" data-tm-unit="minutes">00</span>
        <span class="pw-countdown__label">MINUTOS</span>
      </div>
      <div class="pw-countdown__unit">
        <span class="pw-countdown__num" data-tm-unit="seconds">00</span>
        <span class="pw-countdown__label">SEGUNDOS</span>
      </div>
    </div>

    <div class="pw-spacer" aria-hidden="true"></div>

    <button
      type="button"
      id="pw-access-btn"
      class="pw-access-btn"
      aria-expanded="false"
      aria-controls="pw-form-wrap"
    >
      ACCESO ANTICIPADO &rarr;
    </button>

    <div id="pw-form-wrap" aria-hidden="true">
      {%- form 'storefront_password' -%}
        {%- if form.errors -%}
          <div class="pw-form-errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <input
          type="password"
          name="password"
          id="pw-input"
          class="pw-input"
          placeholder="contrase&ntilde;a"
          autocomplete="current-password"
          {%- if form.errors -%}aria-invalid="true"{%- endif -%}
        >

        <button type="submit" class="pw-submit">ENTRAR</button>
      {%- endform -%}
    </div>

  </main>

  <p class="pw-signature">&mdash; Trajectus Magna.</p>

  {%- comment -%} Requerido por Shopify; la sección password renderiza vacío. {%- endcomment -%}
  {{ content_for_layout }}

  <script src="{{ 'tm-countdown.js' | asset_url }}" defer></script>
  <script>
    (function () {
      var accessBtn = document.getElementById('pw-access-btn');
      var formWrap  = document.getElementById('pw-form-wrap');

      accessBtn.addEventListener('click', function () {
        var isOpen = formWrap.classList.toggle('pw-form--visible');
        accessBtn.setAttribute('aria-expanded', isOpen);
        formWrap.setAttribute('aria-hidden', !isOpen);
        if (isOpen) {
          formWrap.querySelector('input').focus();
        }
      });

      /* Si el envío falló, el form renderiza .pw-form-errors: reabrir el formulario. */
      if (formWrap.querySelector('.pw-form-errors')) {
        formWrap.classList.add('pw-form--visible');
        accessBtn.setAttribute('aria-expanded', 'true');
        formWrap.setAttribute('aria-hidden', 'false');
        formWrap.querySelector('input').focus();
      }
    })();
  </script>

</body>
</html>
