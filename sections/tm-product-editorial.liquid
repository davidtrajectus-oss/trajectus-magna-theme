{%- comment -%} TM — Imagen editorial a ancho completo en producto (v2) {%- endcomment -%}

<div class="tm-pe">
  {%- if section.settings.image != blank -%}
    <img
      src="{{ section.settings.image | image_url: width: 2400 }}"
      srcset="
        {{ section.settings.image | image_url: width: 750 }} 750w,
        {{ section.settings.image | image_url: width: 1100 }} 1100w,
        {{ section.settings.image | image_url: width: 1800 }} 1800w,
        {{ section.settings.image | image_url: width: 2400 }} 2400w
      "
      sizes="100vw"
      alt="{{ section.settings.image.alt | default: 'Trajectus Magna — Editorial' }}"
      class="tm-pe__img"
      loading="lazy"
      width="{{ section.settings.image.width }}"
      height="{{ section.settings.image.height }}"
    >
  {%- else -%}
    <img
      src="{{ 'modelo_sentado_inteiror.png' | asset_url }}"
      alt="Trajectus Magna — Editorial"
      class="tm-pe__img"
      width="1079"
      height="1457"
      loading="lazy"
      onerror="this.onerror=null; this.src='{{ 'modelo_posando_polo_gris.png' | asset_url }}';"
    >
  {%- endif -%}
</div>

{% stylesheet %}
  .tm-pe {
    background: var(--tm-white, #fafaf8);
    padding: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }

  .tm-pe__img {
    width: 100%;
    max-height: 70vh;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "TM Product Editorial",
  "tag": "div",
  "class": "tm-product-editorial-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Editorial photo",
      "info": "Imagen editorial a ancho completo bajo los detalles del producto. Ideal: 2400×1600px o más ancha."
    }
  ],
  "presets": [
    {
      "name": "TM Product Editorial"
    }
  ]
}
{% endschema %}
